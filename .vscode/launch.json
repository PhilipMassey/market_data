{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Current File with Arguments",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "args": "${command:pickArgs}"
        },
        {
            "name": "Run: Cleanup Script",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/cleanup.py",
            "console": "integratedTerminal"
        },
        {
            "name": "Run: Load Holding Portfolios",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/portfolio/load_holding_portfolios.py",
            "console": "integratedTerminal"
        },
        {
            "name": "Run: Load Missing Prices",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/stock_mdb/load_missing.py",
            "console": "integratedTerminal"
        },
        {
            "name": "Run: Update Ticker Metadata",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/database/update_ticker_metadata.py",
            "console": "integratedTerminal",
            "env": {
                "PYTHONPATH": "${workspaceFolder}",
                "RAPID_API_KEY": "${env:RAPID_API_KEY}"
            }
        }
    ]
}